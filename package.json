{
  "name": "libra",
  "version": "0.1.0",
  "description": "Custom TUI renderer for an AI coding harness — inspired by OpenCode and Grok CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "libra": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "bun dist/cli.js",
    "dev": "bun src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test/harness.test.ts && bun test/grok-port.test.ts && bun test/web-tools.test.ts && bun test/stream-layout.test.ts",
    "test:web": "bun test/web-tools.test.ts",
    "test:harness": "bun test/harness.test.ts",
    "test:grok-port": "bun test/grok-port.test.ts",
    "test:layout": "bun test/stream-layout.test.ts",
    "demo": "bun src/cli.ts",
    "compile": "bun build src/cli.ts --compile --outfile dist/libra",
    "link": "bun run build && bun link",
    "unlink": "bun unlink",
    "bench:live": "bun scripts/debug-live-run.ts",
    "bench:score": "bun scripts/score-bench.ts",
    "bench:layout": "bun scripts/bench-tui-stream.ts",
    "bench:heavy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-heavy-benches.ps1",
    "self-review:relaunch": "bun scripts/self-review-relaunch.mjs"
  },
  "keywords": [
    "tui",
    "ai",
    "harness",
    "terminal",
    "agent",
    "cli",
    "bun"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "7.0.2"
  }
}
